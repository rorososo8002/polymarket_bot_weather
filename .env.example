# Public data endpoints. No private key is needed for paper trading.
POLYMARKET_GAMMA_BASE=https://gamma-api.polymarket.com
POLYMARKET_DATA_BASE=https://data-api.polymarket.com
POLYMARKET_CLOB_BASE=https://clob.polymarket.com

# Live paper trading loop. Forecasts refresh every 2 hours; order books stream in real time.
ORDERBOOK_STREAM_ENABLED=true
ORDERBOOK_STREAM_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
ORDERBOOK_STREAM_HEARTBEAT_SECONDS=10
ORDERBOOK_STREAM_RECONNECT_SECONDS=2
# Warn when no order-book price update has arrived for this long.
ORDERBOOK_STREAM_STALE_SECONDS=60
# Refresh paper_runner_status.json while the WebSocket loop waits.
RUNNER_HEALTH_STATUS_INTERVAL_SECONDS=5
FORECAST_REFRESH_INTERVAL_SECONDS=7200
# Maximum city-date weather events to expand. One event can contain many binary markets.
# Fallback API pagination safety only. This does not limit supported cities or weather events.
DISCOVERY_MAX_PAGES=8
DISCOVERY_PAGE_SIZE=100
STATE_PATH=paper_state.json
TRADES_CSV_PATH=paper_trades.csv
DECISIONS_CSV_PATH=paper_decisions.csv
PORTFOLIO_DECISIONS_JSONL_PATH=paper_event_portfolios.jsonl
RAW_SNAPSHOTS_PATH=paper_raw_snapshots.jsonl

# Public whale/external-signal shadow research. This is not copy trading.
SHADOW_SIGNALS_JSONL_PATH=shadow_external_signals.jsonl
SHADOW_PUBLIC_NOTES_JSONL_PATH=shadow_public_notes.jsonl
SHADOW_REPORT_PATH=shadow_signal_report.md
SHADOW_MAX_MARKETS=100
SHADOW_MAX_TRADES_PER_MARKET=100
SHADOW_MAX_ROWS=1000
SHADOW_MIN_TRADE_USDC=100.0
SHADOW_COMPARE_WINDOW_SECONDS=86400

FORECAST_CACHE_PATH=
FORECAST_CACHE_TTL_SECONDS=7200
# Logs real Open-Meteo HTTP attempts. This is a request ledger, not a forecast cache.
FORECAST_REQUEST_LOG_PATH=runtime/forecast_request_log.jsonl
# Persists a daily-limit cooldown after Open-Meteo returns HTTP 429.
FORECAST_RATE_LIMIT_STATE_PATH=runtime/forecast_rate_limit_state.json
# Settlement-station nowcast pilot. Only explicitly mapped stations are used.
STATION_NOWCAST_ENABLED=true
STATION_NOWCAST_CACHE_TTL_SECONDS=900
STATION_NOWCAST_FRESHNESS_SECONDS=5400
# Logs real METAR/HKO observation HTTP attempts. Cache hits do not write rows.
STATION_NOWCAST_REQUEST_LOG_PATH=runtime/station_nowcast_request_log.jsonl

# Human dashboard. Public hosts require a private random DASHBOARD_TOKEN with at least 32 characters.
# Do not use obvious example values such as changeme, placeholder, secret, token, password, abc, or 123456.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8787
DASHBOARD_TOKEN=

# Entry: p_exec is VWAP executable price, so entry slippage is logged for audit only.
# Expected early-exit return conservatively haircuts the future exit by current spread/slippage.
MIN_NET_EDGE=0.05
EXIT_NET_EDGE=0.00
ENTRY_MIN_EXPECTED_NET_RETURN_PCT=0.06

# Exit policy. Stop is based on model probability deterioration.
PROBABILITY_STOP_DROP_THRESHOLD=0.10
MIN_PROFIT_PCT=0.03
TAKE_PROFIT_TO_FAIR_RATIO=0.70
OVERHEAT_MARGIN=0.02
EDGE_FADE_MAX_LOSS_PCT=0.02
MAX_HOLDING_HOURS=96

# Paper bankroll / risk. Money amounts must be greater than 0, and risk fractions must stay between 0 and 1.
# One opened leg must be at least $10.
# A strong single leg may use the full city-date budget.
BANKROLL_USD=100
SIZE_MODE=fixed_fraction
ENTRY_FRACTION=0.10
FRACTIONAL_KELLY=0.10
MAX_SINGLE_MARKET_FRACTION=0.10
MAX_TOTAL_EXPOSURE_FRACTION=0.90
# City-date portfolio: below $1,000, at most two complementary legs share 10%.
# At $1,000 or more, the shared city-date budget shrinks to 5%.
# Different dates for one city share a separate 20% city budget.
MAX_CITY_EXPOSURE_FRACTION=0.20
MAX_EVENT_DATE_EXPOSURE_FRACTION=0.10
LARGE_BANKROLL_EVENT_DATE_EXPOSURE_FRACTION=0.05
EVENT_DATE_EXPOSURE_TRANSITION_USD=1000
MAX_EVENT_PORTFOLIO_LEGS=2
MIN_ORDER_USD=10.00

# Official Polymarket weather taker-fee curve: shares * rate * price * (1 - price).
# Fee rate must stay between 0 and 1.
WEATHER_TAKER_FEE_RATE=0.05
# Profit exits may recover principal and keep a bounded settlement runner.
SETTLEMENT_RUNNER_ENABLED=true
SETTLEMENT_RUNNER_MAX_FRACTION=0.25
SETTLEMENT_RUNNER_MIN_EV_MARGIN_USD=0.00
MODEL_ERROR_MARGIN=0.03
RESOLUTION_ERROR_MARGIN=0.01
PROBABILITY_SHRINK_GAMMA=0.65
DEFAULT_TEMPERATURE_SIGMA_F=4.5
REQUIRE_PARSE_FOR_TRADE=true
REQUIRE_DATE_HINT_FOR_TRADE=true

# Precipitation markets are noisier than temperature markets.
ENABLE_PRECIPITATION_MARKETS=false
PRECIP_MIN_NET_EDGE=0.08
PRECIP_ENTRY_FRACTION=0.025
PRECIP_MIN_CONFIDENCE=0.65
PRECIP_MAX_CONFIDENCE=0.70

# Optional calibration overrides.
# WEATHER_BIAS_JSON=C:\path\to\weather_bias.json
# OPEN_METEO_ENSEMBLE_MODELS=gfs_seamless,ecmwf_ifs025,gem_global
