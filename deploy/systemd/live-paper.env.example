# VPS live paper environment.
# This file is intentionally paper-only. Do not add private keys here.

POLYMARKET_GAMMA_BASE=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE=https://clob.polymarket.com

ORDERBOOK_STREAM_ENABLED=true
ORDERBOOK_STREAM_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
ORDERBOOK_STREAM_HEARTBEAT_SECONDS=10
ORDERBOOK_STREAM_RECONNECT_SECONDS=2
ORDERBOOK_STREAM_STALE_SECONDS=60
RUNNER_HEALTH_STATUS_INTERVAL_SECONDS=5
# Large market-discovery/WebSocket rebuild cycle. This is not the Open-Meteo HTTP request cadence.
FORECAST_REFRESH_INTERVAL_SECONDS=7200
# Maximum city-date weather events to expand. One event can contain many binary markets.
# Fallback API pagination safety only. This does not limit supported cities or weather events.
DISCOVERY_MAX_PAGES=8
DISCOVERY_PAGE_SIZE=100

STATE_PATH=/opt/polymarket-weather-bot/data/paper_state.json
TRADES_CSV_PATH=/opt/polymarket-weather-bot/data/paper_trades.csv
DECISIONS_CSV_PATH=/opt/polymarket-weather-bot/data/paper_decisions.csv
PORTFOLIO_DECISIONS_JSONL_PATH=/opt/polymarket-weather-bot/data/paper_event_portfolios.jsonl
RAW_SNAPSHOTS_PATH=/opt/polymarket-weather-bot/data/paper_raw_snapshots.jsonl
# Raw snapshots are high-volume diagnostics. Default saves only error evidence.
RAW_SNAPSHOTS_MODE=error
RAW_SNAPSHOTS_MAX_BYTES=104857600
RAW_SNAPSHOTS_RETENTION_DAYS=7
RAW_SNAPSHOTS_MIN_FREE_BYTES=1073741824
RAW_SNAPSHOTS_MAX_DISK_USAGE_PCT=0.90
FORECAST_CACHE_PATH=/opt/polymarket-weather-bot/data/forecast_cache.json
FORECAST_CACHE_TTL_SECONDS=2400
FORECAST_REQUEST_MIN_INTERVAL_SECONDS=60
FORECAST_REQUEST_LOG_PATH=/opt/polymarket-weather-bot/data/forecast_request_log.jsonl
FORECAST_RATE_LIMIT_STATE_PATH=/opt/polymarket-weather-bot/data/forecast_rate_limit_state.json
STATION_NOWCAST_ENABLED=true
STATION_NOWCAST_CACHE_TTL_SECONDS=900
STATION_NOWCAST_FRESHNESS_SECONDS=5400
STATION_NOWCAST_REQUEST_LOG_PATH=/opt/polymarket-weather-bot/data/station_nowcast_request_log.jsonl

# Money amounts must be greater than 0, and risk fractions must stay between 0 and 1.
BANKROLL_USD=100
SIZE_MODE=fixed_fraction
ENTRY_FRACTION=0.10
MAX_SINGLE_MARKET_FRACTION=0.10
MAX_TOTAL_EXPOSURE_FRACTION=0.90
# City-date portfolio: below $1,000, at most two complementary legs share 10%.
# At $1,000 or more, the shared city-date budget shrinks to 5%.
# Different dates for one city share a separate 20% city budget.
MAX_CITY_EXPOSURE_FRACTION=0.20
MAX_EVENT_DATE_EXPOSURE_FRACTION=0.10
LARGE_BANKROLL_EVENT_DATE_EXPOSURE_FRACTION=0.05
EVENT_DATE_EXPOSURE_TRANSITION_USD=1000
MAX_EVENT_PORTFOLIO_LEGS=2
MIN_ORDER_USD=10.00

MIN_NET_EDGE=0.05
EXIT_NET_EDGE=0.00
ENTRY_MIN_EXPECTED_NET_RETURN_PCT=0.06
# Fee rate must stay between 0 and 1.
WEATHER_TAKER_FEE_RATE=0.05
MODEL_ERROR_MARGIN=0.03
RESOLUTION_ERROR_MARGIN=0.01
SETTLEMENT_RUNNER_ENABLED=true
SETTLEMENT_RUNNER_MAX_FRACTION=0.25
SETTLEMENT_RUNNER_MIN_EV_MARGIN_USD=0.00

PROBABILITY_STOP_DROP_THRESHOLD=0.10
MIN_PROFIT_PCT=0.03
TAKE_PROFIT_TO_FAIR_RATIO=0.70
OVERHEAT_MARGIN=0.02
EDGE_FADE_MAX_LOSS_PCT=0.02
MAX_HOLDING_HOURS=96

PROBABILITY_SHRINK_GAMMA=0.65
DEFAULT_TEMPERATURE_SIGMA_F=4.5
REQUIRE_PARSE_FOR_TRADE=true
REQUIRE_DATE_HINT_FOR_TRADE=true
# Paper strategy is temperature-only; non-temperature weather settings are intentionally absent.

# Optional calibration overrides.
# WEATHER_BIAS_JSON=/opt/polymarket-weather-bot/config/weather_bias.json
# OPEN_METEO_ENSEMBLE_MODELS=gfs_seamless,ecmwf_ifs025,gem_global
